# .htaccess
<IfModule mod_php.c>
    php_value upload_max_filesize 5M
    php_value post_max_size 8M
    php_value max_file_uploads 20
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    
    # Pass uploads through index.php for proper routing (except PDF files)
    RewriteCond %{REQUEST_URI} ^/api/uploads/ [NC]
    RewriteCond %{REQUEST_URI} !\.pdf$ [NC]
    RewriteRule ^api/uploads/(.*)$ index.php [QSA,L]
    
    # Redirect everything else to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# Add MIME types for video files
<IfModule mod_mime.c>
    AddType video/mp4 .mp4
    AddType video/webm .webm
    AddType video/ogg .ogg
    AddType video/quicktime .mov
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    
    # CORS headers for PDF files to allow embedding in iframes
    <FilesMatch "\.pdf$">
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Allow-Methods "GET, OPTIONS"
        Header set Access-Control-Allow-Headers "Content-Type"
        Header set X-Frame-Options "ALLOW-FROM *"
    </FilesMatch>
</IfModule>

# Disable directory browsing
Options -Indexes

# Protect files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
